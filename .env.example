# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/better_systems_ai"

# Email Service Configuration (for contact forms and notifications)
# Using Resend.com or similar service
RESEND_API_KEY="your_resend_api_key"
EMAIL_FROM="noreply@bettersystemsai.com"
EMAIL_TO="contact@bettersystemsai.com"

# Airtable Configuration
AIRTABLE_API_KEY="your_airtable_api_key"
AIRTABLE_BASE_ID="your_airtable_base_id"
AIRTABLE_TABLE_NAME="your_table_name"

# Authentication Secret
JWT_SECRET="your_jwt_secret_key"

# Node Environment
NODE_ENV="development"

# Port Configuration
PORT=3001

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"

# OpenClaw Mission Control (local-first + VPS fallback)
OPENCLAW_LOCAL_GATEWAY_URL="http://127.0.0.1:18789"
OPENCLAW_VPS_HOST="143.198.74.96"
OPENCLAW_VPS_PORT=18789
OPENCLAW_VPS_GATEWAY_TOKEN="replace_with_vps_token"
OPENCLAW_WORKSPACE_DIR="../OpenClaw-VPS-Setup/workspace"
OPENCLAW_STATE_DIR="~/.openclaw"

# Operator Voice (Admin OpenClaw + OpenAI Realtime)
OPERATOR_VOICE_ENABLED="true"
OPERATOR_TOOLS_ENABLED="true"
OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview"
OPENAI_REALTIME_VOICE="alloy"
